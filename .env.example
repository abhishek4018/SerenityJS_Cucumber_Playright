# Execution mode
# Local run: set USE_LAMBDATEST=false and use BROWSER/ENVIRONMENT
# LambdaTest run: set USE_LAMBDATEST=true and provide LT_* values
USE_LAMBDATEST=false

# shared test target settings
ENVIRONMENT=qa
BROWSER=chromium

# LambdaTest credentials and capabilities (optional)
LT_USERNAME=YOUR_LAMBDATEST_USERNAME
LT_ACCESS_KEY=YOUR_LAMBDATEST_ACCESS_KEY
LT_BROWSER=chromium
LT_BROWSER_VERSION=Latest
LT_PLATFORM=Windows 11
LT_BUILD=Serenity Cucumber Playwright Demo
LT_TEST_NAME=Test
